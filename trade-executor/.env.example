# =============================================================
# Siphon FHE — shared .env for all three services:
#   trade-executor  (python app.py / scheduler.py)
#   fhe             (cargo run — reads ../trade-executor/.env)
#   payload-generator (cargo run — reads ../trade-executor/.env)
# Copy to trade-executor/.env and fill in secrets.
# =============================================================

# --- EVM (Sepolia) ---
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YzVrT5_nZgZhSIQqhq984
EVM_EXECUTOR_KEY=your_evm_executor_private_key_hex
ENTRYPOINT_ADDRESS=0x8Be4A7A074468F571271192A0A0824cf6F08a1f6
UNISWAP_V3_ROUTER=0x3bFA4769FB09eefC5a80d6E87c3B9C650f7Ae48
WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14

# --- Solana ---
HELIUS_API_KEY=your_helius_api_key
SOLANA_NETWORK=devnet
SIPHON_PROGRAM_ID=3CVsp1zayXhNsT8Ktrh85rTewvBJxWy8VcUtQAKdnQMb
EXECUTOR_PRIVATE_KEY=your_solana_executor_private_key_base58

# --- Service URLs (local dev defaults) ---
FHE_ENGINE_URL=http://localhost:5001/evaluateStrategy
ORCHESTRATOR_URL=http://localhost:5005/createStrategy

# --- API Authentication ---
# Used by trade-executor to authenticate incoming requests.
# Payload generator doesn't need this — it calls trade-executor directly.
API_TOKEN=pick_any_secret_string

# --- Price Oracle ---
PYTH_HERMES_URL=https://hermes.pyth.network

# --- Jupiter (Solana swaps) ---
JUPITER_API_URL=https://quote-api.jup.ag/v6

# --- Database ---
DATABASE_URI=sqlite:///strategies.db

# --- Scheduler ---
CHECK_INTERVAL_SECONDS=30

# --- Dev flags ---
LOG_LEVEL=INFO

# --- Li.Fi ---
LIFI_API_KEY=
